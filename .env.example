# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your-api-key

# MongoDB (for migration script - paste your Atlas connection string)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/24digi
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# Public CRM URL (no trailing slash). Used in employee invite emails (must match Firebase → Authentication → Authorized domains). Use http://localhost:5173 for local dev (not 127.0.0.1 unless you add it in Firebase).
# VITE_PUBLIC_APP_URL=http://localhost:5173
# Production example:
# VITE_PUBLIC_APP_URL=https://your-cloudfront-domain.cloudfront.net
#
# Employee invite email (Firebase Console → Authentication → Templates → Password reset):
# The app sets continueUrl to https://YOUR-HOST/employee/<slug> (their workspace). Unauthenticated users are sent to
# /login?next=/employee/<slug> to sign in, then returned to the workspace.
# To show your CRM base URL inside the email body, edit the template and add a line like:
#   After resetting your password, open: https://YOUR-HOST/employee/their-slug
