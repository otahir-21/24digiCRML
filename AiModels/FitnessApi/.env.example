# OpenAI (required for AI endpoints)
OPENAI_API_KEY=sk-...

# Same Firebase project as Flutter — service account JSON as single-line string on App Runner
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Optional
# OPENAI_MODEL=gpt-3.5-turbo

# production = disables test bearer even if FITNESS_API_TEST_BEARER is set (Flutter must use Firebase tokens)
# FITNESS_API_ENV=production

# Postman / local testing only: same string as Authorization Bearer (disables need for real Firebase token)
# FITNESS_API_TEST_BEARER=change-me-long-random-string
# FITNESS_API_TEST_UID=postman_test_user
